{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "rapresence",
      "camelcase": "RAPresence",
      "title": "RAPresence",
      "scope": "source.rapresence",
      "file-types": [
        "rapresence"
      ],
      "injection-regex": "^rapresence$",
      "class-name": "TreeSitterRapresence"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "Rich Presence for RetroAchievement",
    "authors": [
      {
        "name": "Fraise"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-rapresence"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
